<!DOCTYPE html>
<html lang="{{@site.locale}}" data-theme="{{@custom.color_scheme}}" data-heading-font="{{@custom.heading_font}}" data-body-font="{{@custom.body_font}}" data-design="{{@custom.design_mode}}" data-palette="{{@custom.palette}}" data-card-size="{{@custom.card_size}}">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="{{asset "built/index.css"}}" />
    <script src="{{asset "built/index.js"}}" defer></script>
    <style>
        :root { --color-accent: {{@custom.accent_color}}; }
    </style>

    <title>{{meta_title}}</title>

    {{ghost_head}}

</head>
<body class="{{body_class}} pw-theme pw-has-sticky-cta">

    <a href="#pw-main" class="pw-skip-link">Skip to content</a>

    {{> "header"}}

    <main id="pw-main" role="main">
        {{{body}}}
    </main>

    {{> "footer"}}

    {{> "sticky-cta"}}

    {{> "lightbox"}}

    {{!-- Global SVG shape definitions (clipPath for bone-shaped cards, etc.) --}}
