{{!< default}}

{{#post}}
<article class="pw-post {{post_class}}">
    <header class="pw-post-header">
        <div class="pw-container pw-container-narrow">
            {{#primary_tag}}
                <a class="pw-post-tag" href="{{url}}">{{name}}</a>
            {{/primary_tag}}
            <h1 class="pw-post-title">{{title}}</h1>
            {{#if custom_excerpt}}
                <p class="pw-post-lede">{{custom_excerpt}}</p>
            {{/if}}
            <div class="pw-post-meta">
                {{#primary_author}}
                    <span class="pw-post-author">
                        {{#if profile_image}}
                            <img class="pw-post-author-avatar" src="{{img_url profile_image size="xs"}}" alt="{{name}}" loading="lazy" />
                        {{/if}}
                        <span>{{name}}</span>
                    </span>
                {{/primary_author}}
                <span>·</span>
                <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="MMM D, YYYY"}}</time>
                <span>·</span>
                <span>{{reading_time}}</span>
            </div>
        </div>
    </header>

    {{#if feature_image}}
        <figure class="pw-post-feature">
            <img src="{{img_url feature_image size="xxl"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" />
            {{#if feature_image_caption}}
                <figcaption>{{feature_image_caption}}</figcaption>
            {{/if}}
        </figure>
    {{/if}}

    <div class="pw-container pw-container-narrow">
        <div class="pw-post-content pw-prose">
            {{content}}
        </div>

        {{#if tags}}
            <div class="pw-post-tags">
                {{#foreach tags}}
                    <a class="pw-chip" href="{{url}}">#{{name}}</a>
                {{/foreach}}
            </div>
        {{/if}}

        {{#unless @member}}
            {{#if @site.members_enabled}}
                <div class="pw-post-subscribe">
                    {{> "sections/newsletter"}}
                </div>
            {{/if}}
        {{/unless}}

        {{#if comments}}
            <section class="pw-post-comments">
                {{comments}}
            </section>
        {{/if}}
    </div>

    <footer class="pw-post-footer">
        <div class="pw-container">
            <div class="pw-post-nav">
                {{#prev_post}}
                    <a href="{{url}}" class="pw-post-nav-prev">
                        {{> "icons/arrow-left"}}
                        <span>
                            <span class="pw-post-nav-label">Previous</span>
                            <span class="pw-post-nav-title">{{title}}</span>
                        </span>
                    </a>
                {{/prev_post}}
                {{#next_post}}
                    <a href="{{url}}" class="pw-post-nav-next">
                        <span>
                            <span class="pw-post-nav-label">Next</span>
                            <span class="pw-post-nav-title">{{title}}</span>
                        </span>
                        {{> "icons/arrow-right"}}
                    </a>
                {{/next_post}}
            </div>
        </div>
    </footer>
</article>

{{#get "posts" filter="tags:[{{primary_tag.slug}}]+id:-{{id}}" limit="3" as |related|}}
    {{#if related}}
        <section class="pw-section pw-related">
            <div class="pw-container">
                <h2 class="pw-section-title">You might also like</h2>
                <div class="pw-feed-grid">
                    {{#foreach related}}
                        {{> "post-card"}}
                    {{/foreach}}
                </div>
            </div>
        </section>
    {{/if}}
{{/get}}
{{/post}}
