<div class="pw-newsletter" style="margin: var(--sp-7) 0;">
    <h3 class="pw-newsletter-title">Join the pack</h3>
    <p class="pw-newsletter-subtitle">Tips, stories, and the occasional very good dog — straight to your inbox. No spam, unsubscribe any time.</p>
    <form data-members-form="signup" class="pw-form-inline">
        <input class="pw-input" data-members-email type="email" required placeholder="your@email.com" aria-label="Email" />
        <button class="pw-btn" type="submit">Subscribe</button>
    </form>
</div>
