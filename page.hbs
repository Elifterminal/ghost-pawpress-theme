{{!< default}}

{{#post}}
<article class="pw-page {{post_class}}">
    {{#match @page.show_title_and_feature_image}}
        <header class="pw-page-header">
            <div class="pw-container pw-container-narrow">
                <h1 class="pw-page-title">{{title}}</h1>
                {{#if custom_excerpt}}
                    <p class="pw-page-lede">{{custom_excerpt}}</p>
                {{/if}}
            </div>
        </header>

        {{#if feature_image}}
            <figure class="pw-page-feature">
                <img src="{{img_url feature_image size="xxl"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" />
                {{#if feature_image_caption}}
                    <figcaption>{{feature_image_caption}}</figcaption>
                {{/if}}
            </figure>
        {{/if}}
    {{/match}}

    <div class="pw-container pw-container-narrow">
        <div class="pw-page-content pw-prose">
            {{content}}
        </div>
    </div>
</article>
{{/post}}
