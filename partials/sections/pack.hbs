<section class="pw-section pw-pack" id="pack">
    <div class="pw-container">
        <span class="pw-eyebrow" style="display:block;text-align:center;margin:0 auto var(--sp-3);">The team</span>
        <h2 class="pw-section-title">Meet the pack</h2>
        <p class="pw-section-subtitle">The humans and good dogs who make this place what it is.</p>

        <div class="pw-pack-grid">
            {{#get "posts" filter="tag:hash-pack" limit="8" as |pack|}}
                {{#foreach pack}}
                    <article class="pw-pack-card">
                        <div class="pw-pack-avatar">
                            {{#if feature_image}}
                                <img src="{{img_url feature_image size="s"}}" alt="{{title}}" loading="lazy" />
                            {{else}}
                                <img src="{{asset "images/avatar-placeholder.svg"}}" alt="{{title}}" loading="lazy" />
                            {{/if}}
                            <span class="pw-pack-badge">{{> "icons/paw"}}</span>
                        </div>
                        <h3 class="pw-pack-name">{{title}}</h3>
                        {{#if custom_excerpt}}
                            <span class="pw-pack-role">{{custom_excerpt}}</span>
                        {{/if}}
                        {{#if excerpt}}
                            <p class="pw-pack-bio">{{excerpt words="22"}}</p>
                        {{/if}}
                    </article>
                {{/foreach}}
            {{/get}}
        </div>
    </div>
</section>
